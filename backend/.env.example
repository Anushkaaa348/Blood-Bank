PORT=5000
# MongoDB connection string (include database name in path if needed, e.g. .../mydb)
MONGO_URI=
# If you see querySrv ECONNREFUSED with mongodb+srv://, the default fix uses Google/Cloudflare DNS.
# Set to 1 to use only the system DNS (e.g. on a locked-down corporate VPN).
# MONGO_DNS_SYSTEM=1
DB_NAME=test
JWT_SECRET=change-me
EMAIL_USER=
EMAIL_PASS=
FRONTEND_URL=http://localhost:3000
ADMIN_SECRET=
